# Copy to .env.local (git-ignored) and fill in. Never commit real keys.

# --- Browser (Vite exposes only VITE_-prefixed vars to the client) ---
# Safe to ship: every request is constrained by Supabase Row Level Security.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server only (api/ functions; NEVER prefixed with VITE_, never in the client) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM (Wave B; your own OpenRouter key, no-log providers) ---
OPENROUTER_API_KEY=your-openrouter-key
