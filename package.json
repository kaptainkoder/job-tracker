{
  "name": "job-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:parser && npm run test:stages && npm run test:auth && npm run test:profile && npm run test:profile-sync && npm run test:applications && npm run test:outcomes && npm run test:llm && npm run test:privacy && npm run test:privacy-presentation && npm run test:gap && npm run test:fit && npm run test:tailor && npm run test:resume-document && npm run test:resume && npm run test:resume-parse && npm run test:resume-pdf-links && npm run test:api-llm && npm run test:settings && npm run test:application-detail && npm run test:tracker-page && npm run test:tailor-flow && npm run test:resume-review",
    "test:parser": "esbuild src/shared/domain/parser.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:stages": "esbuild src/shared/domain/stages.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:auth": "esbuild src/shared/domain/auth.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:profile": "esbuild src/features/profile/profile.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:profile-sync": "esbuild src/features/profile/profileSync.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:applications": "esbuild src/features/tracker/applications.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:outcomes": "esbuild src/features/outcomes/outcomes.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:llm": "esbuild src/shared/domain/llm.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:privacy": "esbuild src/shared/domain/privacy.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:privacy-presentation": "esbuild src/features/privacy/privacyPresentation.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:gap": "esbuild src/shared/domain/gap.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:fit": "esbuild src/shared/domain/fit.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:tailor": "esbuild src/shared/domain/tailor.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:resume-document": "esbuild src/features/tailor/resumeDocument.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:resume": "esbuild src/shared/domain/resume.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:resume-parse": "esbuild src/shared/domain/resumeParse.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:resume-pdf-links": "esbuild src/features/resume/resumePdfLinks.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:api-llm": "esbuild api/llm.test.ts --bundle --platform=node --format=esm --external:@supabase/supabase-js | node --input-type=module",
    "test:settings": "esbuild src/features/settings/settings.test.ts --bundle --platform=node --format=esm | node --input-type=module",
    "test:application-detail": "node scripts/run-dom-test.mjs src/features/tracker/ApplicationDetail.test.tsx",
    "test:tracker-page": "node scripts/run-dom-test.mjs src/features/tracker/TrackerPage.test.tsx",
    "test:tailor-flow": "node scripts/run-dom-test.mjs src/features/tailor/TailorFlow.test.tsx",
    "test:resume-review": "node scripts/run-dom-test.mjs src/features/resume/ResumeReviewPage.test.tsx",
    "gate": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.395.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^3.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.21.5",
    "jsdom": "^24.1.3",
    "pg": "^8.22.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
